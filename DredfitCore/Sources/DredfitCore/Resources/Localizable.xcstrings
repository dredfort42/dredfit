{
  "sourceLanguage": "en",
  "strings": {
    "Squat": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Squat"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Sentadilla"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Agachamento"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Присед"
          }
        }
      }
    },
    "Feet shoulder-width apart, toes slightly out, weight over the whole foot.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Feet shoulder-width apart, toes slightly out, weight over the whole foot."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Pies a la anchura de los hombros, puntas ligeramente hacia fuera, el peso en todo el pie."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Pés na largura dos ombros, pontas levemente para fora, o peso em todo o pé."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Стопы на ширине плеч, носки слегка наружу, вес на всей стопе."
          }
        }
      }
    },
    "Sit back and down for ~2 seconds; knees track over the toes, back straight.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Sit back and down for ~2 seconds; knees track over the toes, back straight."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Siéntate atrás y abajo durante ~2 segundos; las rodillas siguen la línea de los pies, la espalda recta."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Sente para trás e para baixo por ~2 segundos; os joelhos seguem a linha dos pés, a coluna reta."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Садись назад и вниз ~2 секунды; колени идут за носками, спина прямая."
          }
        }
      }
    },
    "Thighs parallel to the floor at the bottom; drive up on an exhale.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Thighs parallel to the floor at the bottom; drive up on an exhale."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Abajo, los muslos quedan paralelos al suelo; sube soltando el aire."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Embaixo, as coxas ficam paralelas ao chão; suba soltando o ar."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Внизу бедра параллельны полу; вверх — на выдохе."
          }
        }
      }
    },
    "Knees caving inward — keep them tracking over your feet.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Knees caving inward — keep them tracking over your feet."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las rodillas se meten hacia dentro: mantenlas alineadas con los pies."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Os joelhos caem para dentro: mantenha-os alinhados com os pés."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Колени заваливаются внутрь — держи их над стопами."
          }
        }
      }
    },
    "Heels lifting off the floor — depth matters more than speed.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Heels lifting off the floor — depth matters more than speed."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los talones se levantan del suelo: la profundidad importa más que la velocidad."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Os calcanhares saem do chão: a profundidade importa mais que a velocidade."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Пятки отрываются от пола — глубина важнее скорости."
          }
        }
      }
    },
    "Bulgarian split squat": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Bulgarian split squat"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Sentadilla búlgara"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Agachamento búlgaro"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Болгарские приседания"
          }
        }
      }
    },
    "Rear foot on a chair or couch behind you, front foot a stride ahead.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Rear foot on a chair or couch behind you, front foot a stride ahead."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El pie de atrás sobre una silla o un sofá; el de delante, a un paso por delante."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O pé de trás sobre uma cadeira ou sofá; o da frente, um passo à frente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Положи подъем стопы задней ноги на стул или диван; передняя нога — в шаге впереди."
          }
        }
      }
    },
    "Lower straight down until the rear knee almost touches the floor.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Lower straight down until the rear knee almost touches the floor."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Baja en vertical hasta que la rodilla de atrás casi toque el suelo."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Desça na vertical até o joelho de trás quase encostar no chão."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Опускайся вертикально, пока заднее колено почти не коснется пола."
          }
        }
      }
    },
    "Drive up through the front heel; torso leaning slightly forward.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Drive up through the front heel; torso leaning slightly forward."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Sube empujando con el talón de delante; el torso, ligeramente inclinado al frente."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Suba empurrando com o calcanhar da frente; o tronco levemente inclinado à frente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Вверх через пятку передней ноги; корпус слегка наклонен вперед."
          }
        }
      }
    },
    "Stance too short — the front knee travels far past the toes.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Stance too short — the front knee travels far past the toes."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Paso demasiado corto: la rodilla de delante se va muy por delante de la punta del pie."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Passo curto demais: o joelho da frente avança muito além da ponta do pé."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Слишком короткий шаг — колено уходит далеко за носок."
          }
        }
      }
    },
    "Loading the rear leg — it is only there for balance.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Loading the rear leg — it is only there for balance."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cargar la pierna de atrás: solo está ahí para el equilibrio."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Apoiar na perna de trás: ela está ali só para o equilíbrio."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Опора на заднюю ногу — она нужна только для равновесия."
          }
        }
      }
    },
    "Pistol squat": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pistol squat"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Sentadilla pistol"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Agachamento pistol"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Приседания «пистолетик»"
          }
        }
      }
    },
    "Stand on one leg, the other extended forward, arms out for balance.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Stand on one leg, the other extended forward, arms out for balance."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "De pie sobre una pierna, la otra extendida al frente y los brazos delante para equilibrarte."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Em pé sobre uma perna, a outra estendida à frente e os braços à frente para equilibrar."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Стоя на одной ноге, вторую вытяни вперед, руки перед собой для равновесия."
          }
        }
      }
    },
    "Lower slowly until the hamstring rests on the calf, heel on the floor.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Lower slowly until the hamstring rests on the calf, heel on the floor."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Baja despacio hasta apoyar el muslo sobre el gemelo, con el talón en el suelo."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Desça devagar até a coxa encostar na panturrilha, com o calcanhar no chão."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Медленно садись до касания бедром икры, пятка на полу."
          }
        }
      }
    },
    "Stand up without your hands; start with a doorframe assist if needed.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Stand up without your hands; start with a doorframe assist if needed."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Sube sin ayudarte con las manos; al principio puedes sujetarte al marco de una puerta."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Suba sem usar as mãos; no começo dá para se apoiar no batente da porta."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Вверх без помощи рук; сначала можно придерживаться за дверной косяк."
          }
        }
      }
    },
    "Dropping down without control — the descent must be slow.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Dropping down without control — the descent must be slow."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Dejarte caer sin control: el descenso tiene que ser lento."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Cair sem controle: a descida precisa ser lenta."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Падение вниз без контроля — опускайся медленно и подконтрольно."
          }
        }
      }
    },
    "Knee drifting sideways — keep it tracking over the foot.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Knee drifting sideways — keep it tracking over the foot."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La rodilla se va hacia un lado: llévala siempre sobre el pie."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O joelho foge para o lado: conduza-o sempre sobre o pé."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Колено гуляет в сторону — веди его строго над стопой."
          }
        }
      }
    },
    "Shrimp squat": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Shrimp squat"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Sentadilla shrimp"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Agachamento shrimp"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Приседания «креветка»"
          }
        }
      }
    },
    "Stand on one leg; bend the other back and hold its foot with one hand.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Stand on one leg; bend the other back and hold its foot with one hand."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "De pie sobre una pierna, dobla la otra hacia atrás y sujétate el pie con una mano."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Em pé sobre uma perna, dobre a outra para trás e segure o pé com uma das mãos."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Стоя на одной ноге, согни вторую назад и возьми ее стопу рукой."
          }
        }
      }
    },
    "Lower slowly until the back knee gently touches the floor.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Lower slowly until the back knee gently touches the floor."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Baja despacio hasta que la rodilla de atrás toque el suelo con suavidad."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Desça devagar até o joelho de trás tocar o chão com suavidade."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Медленно опускайся, пока заднее колено мягко не коснется пола."
          }
        }
      }
    },
    "Stand up through the heel of the working leg, chest up.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Stand up through the heel of the working leg, chest up."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Sube empujando con el talón de la pierna que trabaja, el pecho arriba."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Suba empurrando com o calcanhar da perna que trabalha, o peito erguido."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Вверх через пятку рабочей ноги, грудь смотрит вперед."
          }
        }
      }
    },
    "Knee crashing into the floor — the descent stays slow and controlled.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Knee crashing into the floor — the descent stays slow and controlled."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La rodilla golpea el suelo: el descenso se mantiene lento y controlado."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O joelho bate no chão: a descida continua lenta e controlada."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Колено ударяется об пол — опускание должно быть медленным."
          }
        }
      }
    },
    "Leaning far forward — keep the chest up and the core braced.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Leaning far forward — keep the chest up and the core braced."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Inclinarte demasiado al frente: pecho arriba y abdomen firme."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Inclinar demais para a frente: peito erguido e abdômen firme."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Сильный наклон вперед — держи грудь выше, мышцы корпуса в напряжении."
          }
        }
      }
    },
    "Knee push-up": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Knee push-up"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Flexión con rodillas"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Flexão com joelhos"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Отжимания с колен"
          }
        }
      }
    },
    "Hands under the shoulders, knees on the floor; head to knees form a straight line.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Hands under the shoulders, knees on the floor; head to knees form a straight line."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Manos bajo los hombros, rodillas en el suelo; de la cabeza a las rodillas, una línea recta."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Mãos sob os ombros, joelhos no chão; da cabeça aos joelhos, uma linha reta."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Ладони под плечами, колени на полу; от макушки до колен — прямая линия."
          }
        }
      }
    },
    "Lower for ~2 seconds until the chest nearly touches the floor, elbows about 45° from the torso.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Lower for ~2 seconds until the chest nearly touches the floor, elbows about 45° from the torso."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Baja durante ~2 segundos hasta casi tocar el suelo con el pecho, los codos a unos 45° del torso."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Desça por ~2 segundos até o peito quase tocar o chão, os cotovelos a cerca de 45° do tronco."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Опускайся ~2 секунды до касания грудью пола, локти под 45° к корпусу."
          }
        }
      }
    },
    "Press up on an exhale, keeping the belly tight.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Press up on an exhale, keeping the belly tight."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Empuja hacia arriba soltando el aire, con el abdomen apretado."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Empurre para cima soltando o ar, com a barriga contraída."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Вверх на выдохе, живот подтянут."
          }
        }
      }
    },
    "Sagging hips — squeeze your glutes and abs.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Sagging hips — squeeze your glutes and abs."
          }
        },
