        }
      }
    },
    "Hips hiked up — easier, but pointless.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Hips hiked up — easier, but pointless."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Таз задран вверх — так легче, но бесполезнее."
          }
        }
      }
    },
    "Lower back sagging — that strains the spine; better to stop early.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Lower back sagging — that strains the spine; better to stop early."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Поясница провисает — это риск для спины, лучше закончить раньше."
