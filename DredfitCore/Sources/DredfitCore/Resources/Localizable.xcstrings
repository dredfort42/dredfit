          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Codos abiertos a 90°: mantenlos más cerca del torso."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Cotovelos abertos a 90°: mantenha-os mais perto do tronco."
