        }
      }
    },
    "Losing balance — fix your eyes on a point ahead.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Losing balance — fix your eyes on a point ahead."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Pérdida de equilibrio: fija la mirada en un punto al frente."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Perda de equilíbrio: fixe o olhar num ponto à frente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Потеря равновесия — фиксируй взгляд перед собой."
          }
        }
      }
    },
    "Jump lunge": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Jump lunge"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Zancada con salto"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Afundo com salto"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Выпады в прыжке"
          }
        }
      }
    },
    "From a lunge, jump up and switch legs in the air.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "From a lunge, jump up and switch legs in the air."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Desde la zancada, salta y cambia de pierna en el aire."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Do afundo, salte e troque as pernas no ar."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Из позиции выпада выпрыгни вверх и смени ноги в воздухе."
          }
        }
      }
    },
    "Land softly in a lunge on the other side, knee almost to the floor.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Land softly in a lunge on the other side, knee almost to the floor."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cae suave en zancada con la otra pierna, la rodilla casi en el suelo."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Caia suave em afundo do outro lado, o joelho quase no chão."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Приземляйся мягко в выпад на другую ногу, колено почти до пола."
          }
        }
      }
    },
    "Keep a steady rhythm; use the arms for balance.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Keep a steady rhythm; use the arms for balance."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Mantén un ritmo constante; ayúdate con los brazos para equilibrarte."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Mantenha um ritmo constante; use os braços para equilibrar."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Держи ритм; руки помогают удерживать равновесие."
          }
        }
      }
    },
    "Landing stiff on a straight leg — absorb by bending.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Landing stiff on a straight leg — absorb by bending."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Caer rígido con la pierna estirada: amortigua flexionando."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Cair duro com a perna esticada: amorteça flexionando."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Жесткое приземление на прямую ногу — амортизируй сгибанием."
          }
        }
      }
    },
    "Knee slamming into the floor — control the depth.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Knee slamming into the floor — control the depth."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La rodilla golpea el suelo: controla la profundidad."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O joelho bate no chão: controle a profundidade."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Колено бьется об пол — контролируй глубину."
          }
        }
      }
    },
    "Paused jump lunge": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Paused jump lunge"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Zancada con salto y pausa"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Afundo com salto e pausa"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Выпады в прыжке с паузой"
          }
        }
      }
    },
    "Jump and switch legs in the air, landing softly in a lunge.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Jump and switch legs in the air, landing softly in a lunge."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Salta cambiando de pierna en el aire y cae suave en zancada."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Salte trocando as pernas no ar e caia suave em afundo."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Выпрыгни со сменой ног в воздухе, приземлись мягко в выпад."
          }
        }
      }
    },
    "Hold the bottom position for a full 2 seconds, knee near the floor.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Hold the bottom position for a full 2 seconds, knee near the floor."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Aguanta abajo 2 segundos completos, con la rodilla cerca del suelo."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Segure embaixo por 2 segundos completos, com o joelho perto do chão."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Задержись внизу на честные 2 секунды, колено у пола."
          }
        }
      }
    },
    "Explode up into the next switch — pause every landing.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Explode up into the next switch — pause every landing."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Sal hacia arriba de forma explosiva al siguiente cambio: pausa en cada aterrizaje."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Exploda para cima na próxima troca: pausa em cada aterrissagem."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Взрывно выпрыгни в следующую смену — пауза на каждом приземлении."
          }
        }
      }
    },
    "Skipping the pause — hold an honest 2 seconds at the bottom.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Skipping the pause — hold an honest 2 seconds at the bottom."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Saltarte la pausa: aguanta 2 segundos honestos abajo."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Pular a pausa: segure 2 segundos honestos embaixo."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Пауза пропускается — держи честные 2 секунды внизу."
          }
        }
      }
    },
    "Shallow landings — the knee comes close to the floor each rep.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Shallow landings — the knee comes close to the floor each rep."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Aterrizajes cortos: la rodilla baja cerca del suelo en cada repetición."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Aterrissagens curtas: o joelho desce perto do chão em cada repetição."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Мелкие приземления — колено опускается к полу каждый повтор."
          }
        }
      }
    },
    "Knee plank": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Knee plank"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Plancha con rodillas"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Prancha com joelhos"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Планка на коленях"
          }
        }
      }
    },
    "Forearms on the floor, elbows under the shoulders, knees down.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Forearms on the floor, elbows under the shoulders, knees down."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Antebrazos en el suelo, codos bajo los hombros, rodillas apoyadas."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Antebraços no chão, cotovelos sob os ombros, joelhos apoiados."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Предплечья на полу, локти под плечами, колени на полу."
