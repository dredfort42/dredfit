{
  "sourceLanguage": "en",
  "strings": {
    "Squat": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Squat"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Присед"
          }
        }
      }
    },
    "Feet shoulder-width apart, toes slightly out, weight over the whole foot.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Feet shoulder-width apart, toes slightly out, weight over the whole foot."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Стопы на ширине плеч, носки слегка наружу, вес на всей стопе."
          }
        }
      }
    },
    "Sit back and down for ~2 seconds; knees track over the toes, back straight.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Sit back and down for ~2 seconds; knees track over the toes, back straight."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Садись назад и вниз ~2 секунды; колени идут за носками, спина прямая."
          }
        }
      }
    },
    "Thighs parallel to the floor at the bottom; drive up on an exhale.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Thighs parallel to the floor at the bottom; drive up on an exhale."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Внизу бёдра параллельны полу; вверх — на выдохе."
          }
        }
      }
    },
    "Knees caving inward — keep them tracking over your feet.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Knees caving inward — keep them tracking over your feet."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Колени заваливаются внутрь — держи их над стопами."
          }
        }
      }
    },
    "Heels lifting off the floor — depth matters more than speed.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Heels lifting off the floor — depth matters more than speed."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Пятки отрываются от пола — глубина важнее скорости."
          }
        }
      }
    },
    "Bulgarian split squat": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Bulgarian split squat"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Болгарские приседания"
          }
        }
      }
    },
    "Rear foot on a chair or couch behind you, front foot a stride ahead.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Rear foot on a chair or couch behind you, front foot a stride ahead."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Положи подъём стопы задней ноги на стул или диван; передняя нога — в шаге впереди."
          }
        }
      }
    },
    "Lower straight down until the rear knee almost touches the floor.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Lower straight down until the rear knee almost touches the floor."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Опускайся вертикально, пока заднее колено почти не коснётся пола."
          }
        }
      }
    },
    "Drive up through the front heel; torso leaning slightly forward.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Drive up through the front heel; torso leaning slightly forward."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Вверх через пятку передней ноги; корпус слегка наклонён вперёд."
          }
        }
      }
    },
    "Stance too short — the front knee travels far past the toes.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Stance too short — the front knee travels far past the toes."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Слишком короткий шаг — колено уходит далеко за носок."
          }
        }
      }
    },
    "Loading the rear leg — it is only there for balance.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Loading the rear leg — it is only there for balance."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Опора на заднюю ногу — она нужна только для равновесия."
          }
        }
      }
    },
    "Pistol squat": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pistol squat"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Приседания «пистолетик»"
          }
        }
      }
    },
    "Stand on one leg, the other extended forward, arms out for balance.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Stand on one leg, the other extended forward, arms out for balance."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Стоя на одной ноге, вторую вытяни вперёд, руки перед собой для равновесия."
          }
        }
      }
    },
    "Lower slowly until the hamstring rests on the calf, heel on the floor.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Lower slowly until the hamstring rests on the calf, heel on the floor."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Медленно садись до касания бедром икры, пятка на полу."
          }
        }
      }
    },
    "Stand up without your hands; start with a doorframe assist if needed.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Stand up without your hands; start with a doorframe assist if needed."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Вверх без помощи рук; сначала можно придерживаться за дверной косяк."
          }
        }
      }
    },
    "Dropping down without control — the descent must be slow.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Dropping down without control — the descent must be slow."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Падение вниз без контроля — опускайся медленно и подконтрольно."
          }
        }
      }
    },
    "Knee drifting sideways — keep it tracking over the foot.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Knee drifting sideways — keep it tracking over the foot."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Колено гуляет в сторону — веди его строго над стопой."
          }
        }
      }
    },
    "Shrimp squat": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Shrimp squat"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Приседания «креветка»"
          }
        }
      }
    },
    "Stand on one leg; bend the other back and hold its foot with one hand.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Stand on one leg; bend the other back and hold its foot with one hand."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Стоя на одной ноге, согни вторую назад и возьми её стопу рукой."
          }
        }
      }
    },
    "Lower slowly until the back knee gently touches the floor.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Lower slowly until the back knee gently touches the floor."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Медленно опускайся, пока заднее колено мягко не коснётся пола."
          }
        }
      }
    },
    "Stand up through the heel of the working leg, chest up.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Stand up through the heel of the working leg, chest up."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Вверх через пятку рабочей ноги, грудь смотрит вперёд."
          }
        }
      }
    },
    "Knee crashing into the floor — the descent stays slow and controlled.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Knee crashing into the floor — the descent stays slow and controlled."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Колено ударяется об пол — опускание должно быть медленным."
          }
        }
      }
    },
    "Leaning far forward — keep the chest up and the core braced.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Leaning far forward — keep the chest up and the core braced."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Сильный наклон вперёд — держи грудь выше, мышцы корпуса в напряжении."
          }
        }
      }
    },
    "Knee push-up": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Knee push-up"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Отжимания с колен"
          }
        }
      }
    },
    "Hands under the shoulders, knees on the floor; head to knees form a straight line.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Hands under the shoulders, knees on the floor; head to knees form a straight line."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Ладони под плечами, колени на полу; от макушки до колен — прямая линия."
          }
        }
      }
    },
    "Lower for ~2 seconds until the chest nearly touches the floor, elbows about 45° from the torso.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Lower for ~2 seconds until the chest nearly touches the floor, elbows about 45° from the torso."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Опускайся ~2 секунды до касания грудью пола, локти под 45° к корпусу."
          }
        }
      }
    },
    "Press up on an exhale, keeping the belly tight.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Press up on an exhale, keeping the belly tight."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Вверх на выдохе, живот подтянут."
          }
        }
      }
    },
    "Sagging hips — squeeze your glutes and abs.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Sagging hips — squeeze your glutes and abs."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Таз провисает — включи пресс и ягодицы."
          }
        }
      }
    },
    "Cutting the range short — the chest should almost touch the floor.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Cutting the range short — the chest should almost touch the floor."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Короткая амплитуда — грудь должна почти касаться пола."
          }
        }
      }
    },
    "Push-up": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Push-up"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Отжимания классические"
          }
        }
      }
    },
    "Hands under the shoulders; the body is one straight line from head to heels.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Hands under the shoulders; the body is one straight line from head to heels."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Ладони под плечами; тело — прямая линия от макушки до пят."
          }
        }
      }
    },
    "Press up on an exhale; don't fully lock the elbows at the top.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Press up on an exhale; don't fully lock the elbows at the top."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Вверх на выдохе; в верхней точке не блокируй локти полностью."
          }
        }
      }
    },
    "Sagging hips or a raised butt — the core stops working.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Sagging hips or a raised butt — the core stops working."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Провисший таз или поднятые ягодицы — выключаются мышцы корпуса."
          }
        }
      }
    },
    "Elbows flared out to 90° — this overloads the shoulders.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Elbows flared out to 90° — this overloads the shoulders."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Локти разведены на 90° в стороны — перегружаются плечи."
          }
        }
      }
    },
    "Feet-elevated push-up": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Feet-elevated push-up"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Отжимания, ноги на возвышении"
          }
        }
      }
    },
    "Feet on a chair or couch, hands under the shoulders on the floor.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Feet on a chair or couch, hands under the shoulders on the floor."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Стопы на стуле или диване, ладони под плечами на полу."
          }
        }
      }
    },
    "Keep the body rigid and lower until the chest nearly touches the floor.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Keep the body rigid and lower until the chest nearly touches the floor."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Держи корпус жёстким, опускайся до касания грудью пола."
          }
        }
      }
    },
    "The higher the support, the harder it gets — start low.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The higher the support, the harder it gets — start low."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Чем выше опора для ног, тем тяжелее — начинай с невысокой."
          }
        }
      }
    },
    "Lower back arching — don't let the hips sag.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Lower back arching — don't let the hips sag."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Прогиб в пояснице — таз не должен провисать."
          }
        }
      }
    },
    "Leading with the head — keep the neck in line with the torso.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Leading with the head — keep the neck in line with the torso."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Голова опускается первой — шея на одной линии с корпусом."
          }
        }
      }
    },
    "Archer push-up": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Archer push-up"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Отжимания «лучник»"
          }
        }
      }
    },
    "Take a wide hand position; the body stays one straight line.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Take a wide hand position; the body stays one straight line."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Поставь руки широко; тело — одна прямая линия."
          }
        }
      }
    },
    "Lower toward one hand, bending that elbow; the other arm stays straight.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Lower toward one hand, bending that elbow; the other arm stays straight."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Опускайся к одной руке, сгибая её локоть; вторая рука прямая."
          }
        }
      }
    },
    "Press up and repeat to the same side for the whole set, then switch.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Press up and repeat to the same side for the whole set, then switch."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Выжмись вверх; весь подход в одну сторону, затем смени руку."
          }
        }
      }
    },
    "Hips rotating — shoulders and hips stay square to the floor.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Hips rotating — shoulders and hips stay square to the floor."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Разворот таза — плечи и таз параллельны полу."
          }
        }
      }
    },
    "Half range — the chest goes down to the working hand.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Half range — the chest goes down to the working hand."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Неполная амплитуда — грудь опускается к рабочей руке."
          }
        }
      }
    },
    "Glute bridge": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Glute bridge"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Ягодичный мостик"
          }
        }
      }
    },
    "Lie on your back, feet close to the glutes hip-width apart, arms at your sides.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Lie on your back, feet close to the glutes hip-width apart, arms at your sides."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Лёжа на спине, стопы у ягодиц на ширине таза, руки вдоль тела."
          }
        }
      }
    },
    "Lift the hips until knees, hips and shoulders form one straight line.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Lift the hips until knees, hips and shoulders form one straight line."
          }
        },
        "ru": {
