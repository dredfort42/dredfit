        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Passo para trás curto demais: o joelho da frente fica sobrecarregado."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Слишком короткий шаг назад — перегружается переднее колено."
