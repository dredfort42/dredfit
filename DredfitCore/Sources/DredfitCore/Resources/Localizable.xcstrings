    },
    "Head to knees — one straight line; belly pulled in.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Head to knees — one straight line; belly pulled in."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "De la cabeza a las rodillas, una línea recta; el abdomen metido."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Da cabeça aos joelhos, uma linha reta; a barriga contraída."
          }
