        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Дыши ровно и держи время из плана."
          }
        }
      }
    },
    "Hips sagging — tuck the pelvis slightly.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Hips sagging — tuck the pelvis slightly."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La cadera se hunde: bascula un poco la pelvis."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O quadril afunda: incline a pelve levemente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Таз провисает — слегка подкрути его на себя."
          }
        }
      }
    },
    "Shoulders at the ears — push the floor away, keep the neck long.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Shoulders at the ears — push the floor away, keep the neck long."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Hombros pegados a las orejas: empuja el suelo y alarga el cuello."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Ombros colados nas orelhas: empurre o chão e alongue o pescoço."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Плечи у ушей — оттолкнись от пола, шея длинная."
          }
        }
      }
    },
    "Plank": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Plank"
          }
        },
        "es": {
