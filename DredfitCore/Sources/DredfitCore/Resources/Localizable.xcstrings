        }
      }
    },
    "Archer inverted row": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Archer inverted row"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Remo invertido de arquero"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Remada invertida arqueiro"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Тяга «лучник» с опорой"
          }
        }
      }
    },
    "Set up under the table with a wide grip, body straight.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Set up under the table with a wide grip, body straight."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Colócate bajo la mesa con un agarre ancho y el cuerpo recto."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Posicione-se embaixo da mesa com pegada aberta e o corpo reto."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Ляг под стол и возьмись за край широким хватом, тело прямое."
          }
        }
      }
    },
    "Pull the chest toward one hand; the other arm stays nearly straight.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pull the chest toward one hand; the other arm stays nearly straight."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Lleva el pecho hacia una mano; el otro brazo se queda casi estirado."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Puxe o peito em direção a uma das mãos; o outro braço fica quase estendido."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Тяни грудь к одной руке; вторая рука почти прямая."
          }
        }
      }
    },
    "Lower under control; whole set to one side, then switch.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Lower under control; whole set to one side, then switch."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Baja con control; toda la serie a un lado y después cambia."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Desça com controle; a série inteira de um lado e depois troque."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Опускайся под контролем; весь подход в одну сторону, затем смена."
          }
        }
      }
    },
    "Hips sagging — hold the plank line through the set.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Hips sagging — hold the plank line through the set."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La cadera se hunde: sostén la línea de plancha durante toda la serie."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O quadril afunda: sustente a linha da prancha durante toda a série."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Таз провисает — держи линию планки весь подход."
          }
        }
      }
    },
    "Both arms pulling equally — the working arm does the job.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Both arms pulling equally — the working arm does the job."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los dos brazos tiran por igual: el trabajo lo hace el brazo activo."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Os dois braços puxam igual: quem faz o trabalho é o braço ativo."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Обе руки тянут одинаково — работать должна одна."
          }
        }
      }
    },
    "Wall push-up": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Wall push-up"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Flexión en la pared"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Flexão na parede"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Отжимания у стены"
          }
        }
      }
    },
    "Stand a step away from a wall, palms on it slightly wider than shoulders, at chest height.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Stand a step away from a wall, palms on it slightly wider than shoulders, at chest height."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ponte a un paso de la pared, con las palmas en ella algo más abiertas que los hombros, a la altura del pecho."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Fique a um passo da parede, com as palmas nela um pouco mais abertas que os ombros, na altura do peito."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Встань в шаге от стены, ладони на ней чуть шире плеч на уровне груди."
          }
        }
      }
    },
    "Bend the elbows, bringing the face toward the wall, body in one line.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Bend the elbows, bringing the face toward the wall, body in one line."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Dobla los codos acercando la cara a la pared, con el cuerpo en una línea."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Dobre os cotovelos aproximando o rosto da parede, com o corpo em uma linha."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Согни локти, приближая лицо к стене, тело — одна линия."
          }
        }
      }
    },
    "Push back to straight arms; the farther the feet, the harder.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Push back to straight arms; the farther the feet, the harder."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Empuja hasta estirar los brazos; cuanto más lejos los pies, más difícil."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Empurre até esticar os braços; quanto mais longe os pés, mais difícil."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Оттолкнись до прямых рук; чем дальше стопы, тем тяжелее."
          }
        }
      }
    },
    "Hips dropping back — the whole body moves as one line.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Hips dropping back — the whole body moves as one line."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La cadera se va hacia atrás: todo el cuerpo se mueve como una sola línea."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O quadril vai para trás: o corpo inteiro se move como uma linha só."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Таз уходит назад — двигается все тело единой линией."
          }
        }
      }
    },
    "Elbows flared to 90° — keep them closer to the torso.": {
      "extractionState": "manual",
