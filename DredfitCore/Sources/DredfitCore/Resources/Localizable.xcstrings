            "value": "Секунда паузы вверху, медленно вниз."
          }
        }
      }
    },
    "Pelvis tilting sideways — keep both hip bones pointing at the ceiling.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pelvis tilting sideways — keep both hip bones pointing at the ceiling."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La pelvis se inclina hacia un lado: los dos huesos de la cadera miran al techo."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A pelve inclina para o lado: os dois ossos do quadril apontam para o teto."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Таз перекашивается — обе тазовые кости смотрят в потолок."
          }
        }
      }
    },
    "Helping with the free leg — it stays out of the movement.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Helping with the free leg — it stays out of the movement."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ayudarte con la pierna libre: no participa en el movimiento."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajudar com a perna livre: ela não participa do movimento."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Помощь свободной ногой — она не участвует в движении."
          }
        }
      }
    },
    "Single-leg Romanian deadlift": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Single-leg Romanian deadlift"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Peso muerto rumano a una pierna"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Levantamento terra romeno unilateral"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Румынская тяга на одной ноге"
          }
        }
      }
    },
    "Stand on one leg with a soft knee; hinge forward from the hips with a flat back.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Stand on one leg with a soft knee; hinge forward from the hips with a flat back."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "De pie sobre una pierna con la rodilla algo flexionada, inclínate al frente desde la cadera con la espalda recta."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Em pé sobre uma perna com o joelho levemente flexionado, incline para a frente a partir do quadril com a coluna reta."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Стоя на одной ноге с мягким коленом, наклоняйся вперед с прямой спиной."
          }
        }
      }
    },
    "The free leg extends back; torso and leg form one line, hands reaching toward the floor.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The free leg extends back; torso and leg form one line, hands reaching toward the floor."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La pierna libre se va hacia atrás; torso y pierna forman una línea, las manos bajan hacia el suelo."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A perna livre vai para trás; tronco e perna formam uma linha, as mãos descem em direção ao chão."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Свободная нога уходит назад; корпус и нога — одна линия, руки к полу."
          }
        }
      }
    },
    "Stand back up by squeezing the glute of the standing leg.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Stand back up by squeezing the glute of the standing leg."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Vuelve a subir apretando el glúteo de la pierna de apoyo."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Volte a subir apertando o glúteo da perna de apoio."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Поднимись обратно, напрягая ягодицу опорной ноги."
          }
        }
      }
    },
    "Rounding the back — keep the shoulder blades set, hinge from the hips.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Rounding the back — keep the shoulder blades set, hinge from the hips."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Espalda redondeada: mantén las escápulas firmes y bascula desde la cadera."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Coluna arredondada: mantenha as escápulas firmes e incline a partir do quadril."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Круглая спина — держи лопатки собранными, наклон из таза."
          }
        }
      }
    },
    "Pelvis rotating open — keep the hips square to the floor.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pelvis rotating open — keep the hips square to the floor."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La pelvis se abre: mantén las caderas paralelas al suelo."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A pelve abre para o lado: mantenha os quadris paralelos ao chão."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Разворот таза в сторону — бедра параллельны полу."
          }
        }
      }
    },
    "Sliding leg curl": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Sliding leg curl"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Curl femoral deslizante"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Curl femoral deslizante"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Сгибание ног скольжением"
          }
        }
      }
    },
    "Lie on your back, heels on a towel on a smooth floor, hips lifted.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Lie on your back, heels on a towel on a smooth floor, hips lifted."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Acostado boca arriba, talones sobre una toalla en suelo liso y la cadera elevada."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Deitado de costas, calcanhares sobre uma toalha em piso liso e o quadril elevado."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Лежа на спине, пятки на полотенце на гладком полу, таз поднят."
          }
        }
      }
    },
    "Slide the heels away until the legs are almost straight, hips stay up.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Slide the heels away until the legs are almost straight, hips stay up."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Desliza los talones hacia fuera hasta casi estirar las piernas; la cadera no baja."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Deslize os calcanhares para longe até as pernas quase esticarem; o quadril não desce."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Скользи пятками от себя почти до прямых ног, таз не опускается."
          }
        }
      }
    },
    "Pull the heels back toward the glutes — that's one rep.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pull the heels back toward the glutes — that's one rep."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Trae los talones de vuelta hacia los glúteos: eso es una repetición."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Traga os calcanhares de volta em direção aos glúteos: isso é uma repetição."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Подтяни пятки обратно к ягодицам — это один повтор."
          }
        }
      }
    },
    "Hips dropping as the legs extend — keep the bridge the whole time.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Hips dropping as the legs extend — keep the bridge the whole time."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La cadera cae al estirar las piernas: mantén el puente todo el rato."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O quadril cai quando as pernas esticam: mantenha a ponte o tempo todo."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Таз падает при выпрямлении ног — держи мостик все время."
          }
        }
      }
    },
    "Jerky pulls — slide out and back slowly, with control.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Jerky pulls — slide out and back slowly, with control."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tirones bruscos: desliza hacia fuera y hacia dentro despacio, con control."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Puxadas bruscas: deslize para fora e para dentro devagar, com controle."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Рывки — скользи туда и обратно медленно, под контролем."
          }
        }
      }
    },
    "Y-T-W raises": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Y-T-W raises"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elevaciones Y-T-W"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Elevações Y-T-W"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Разведения Y-T-W лежа"
          }
        }
      }
    },
    "Lie face down, forehead near the floor, arms extended in a Y shape.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Lie face down, forehead near the floor, arms extended in a Y shape."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Acostado boca abajo, la frente cerca del suelo y los brazos extendidos formando una Y."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Deitado de barriga para baixo, a testa perto do chão e os braços estendidos formando um Y."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Лежа на животе, лоб у пола, руки вытянуты в форме буквы Y."
          }
        }
      }
    },
    "Lift the straight arms for 2 seconds, squeezing the shoulder blades, then lower.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Lift the straight arms for 2 seconds, squeezing the shoulder blades, then lower."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Sube los brazos estirados durante 2 segundos juntando las escápulas y baja."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Suba os braços esticados por 2 segundos juntando as escápulas e desça."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Подними прямые руки на 2 секунды, сведя лопатки, опусти."
          }
        }
      }
    },
    "Repeat in a T position and a W position — together that's one rep.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Repeat in a T position and a W position — together that's one rep."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Repite en posición de T y de W: las tres juntas son una repetición."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Repita na posição de T e na de W: as três juntas são uma repetição."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Повтори в позиции T и W — вместе это один повтор."
          }
        }
      }
    },
    "Jerking the torso up — only the arms and shoulder blades lift.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Jerking the torso up — only the arms and shoulder blades lift."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Subir el torso de un tirón: solo se levantan los brazos y las escápulas."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Subir o tronco num arranco: só os braços e as escápulas se levantam."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Рывок корпусом — поднимаются только руки и лопатки."
          }
        }
      }
    },
    "Shoulders creeping toward the ears — pull the blades down and back.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Shoulders creeping toward the ears — pull the blades down and back."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los hombros se van hacia las orejas: lleva las escápulas abajo y atrás."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Os ombros sobem em direção às orelhas: puxe as escápulas para baixo e para trás."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Плечи ползут к ушам — тяни лопатки вниз и назад."
          }
        }
      }
    },
    "Inverted row (table)": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Inverted row (table)"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Remo invertido (mesa)"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Remada invertida (mesa)"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Тяга с опорой"
          }
        }
      }
    },
    "Lie under a sturdy table and grab the edge with a shoulder-width grip.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Lie under a sturdy table and grab the edge with a shoulder-width grip."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Acuéstate bajo una mesa firme y agarra el borde con las manos a la anchura de los hombros."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Deite embaixo de uma mesa firme e segure a borda com as mãos na largura dos ombros."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Ляг под прочный стол и возьмись за край хватом на ширине плеч."
          }
        }
      }
    },
    "Body straight from shoulders to heels; pull the chest to the edge, squeezing the shoulder blades.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Body straight from shoulders to heels; pull the chest to the edge, squeezing the shoulder blades."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cuerpo recto de los hombros a los talones; lleva el pecho al borde juntando las escápulas."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Corpo reto dos ombros aos calcanhares; puxe o peito até a borda juntando as escápulas."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Тело прямое от плеч до пят; подтяни грудь к краю, сводя лопатки."
          }
        }
      }
    },
    "Lower slowly until the arms are straight.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Lower slowly until the arms are straight."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Baja despacio hasta estirar del todo los brazos."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Desça devagar até esticar os braços por completo."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Медленно опустись до прямых рук."
          }
        }
      }
    },
    "Sagging hips — hold the body like a plank.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Sagging hips — hold the body like a plank."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La cadera se hunde: sostén el cuerpo como en una plancha."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O quadril afunda: sustente o corpo como numa prancha."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Таз провисает — держи корпус как в планке."
          }
        }
      }
    },
    "Pulling only with the arms — start by squeezing the shoulder blades.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pulling only with the arms — start by squeezing the shoulder blades."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tirar solo con los brazos: el movimiento empieza juntando las escápulas."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Puxar só com os braços: o movimento começa juntando as escápulas."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Тяга только руками — движение начинается со сведения лопаток."
          }
        }
      }
    },
    "Feet-elevated inverted row": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Feet-elevated inverted row"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Remo invertido con pies elevados"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Remada invertida com pés elevados"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Тяга с опорой, ноги на возвышении"
          }
        }
      }
    },
    "Same setup, but feet up on a chair — the body is parallel to the floor.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Same setup, but feet up on a chair — the body is parallel to the floor."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La misma posición, pero con los pies sobre una silla: el cuerpo queda paralelo al suelo."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A mesma posição, mas com os pés sobre uma cadeira: o corpo fica paralelo ao chão."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "То же, но стопы подняты на стул — тело параллельно полу."
          }
        }
      }
    },
    "Pull the chest to the table edge with a rigid torso.": {
