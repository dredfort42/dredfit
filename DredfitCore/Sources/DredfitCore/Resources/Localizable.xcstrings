    "Rushing the reps — control both directions.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Rushing the reps — control both directions."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
