      }
    },
    "One straight line from head to heels; glutes and abs braced.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "One straight line from head to heels; glutes and abs braced."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Прямая линия от макушки до пят; ягодицы и пресс в тонусе."
          }
        }
      }
    },
    "Breathe steadily; shaking is fine, a sagging line is not.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Breathe steadily; shaking is fine, a sagging line is not."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Дыши ровно; дрожь мышц — норма, провал линии — стоп."
