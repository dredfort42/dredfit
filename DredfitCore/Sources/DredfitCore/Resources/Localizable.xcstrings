        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Локти разведены на 90° — держи их ближе к корпусу."
          }
        }
      }
    },
    "Pike push-up": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pike push-up"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Flexión pica"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Flexão pike"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Отжимания уголком"
          }
        }
      }
    },
    "From a push-up position, lift the hips high — the body forms an inverted V.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "From a push-up position, lift the hips high — the body forms an inverted V."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Desde la posición de flexión, sube mucho la cadera: el cuerpo forma una V invertida."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Da posição de flexão, suba bem o quadril: o corpo forma um V invertido."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Из упора лежа подними таз вверх — тело углом, перевернутой V."
          }
        }
      }
    },
    "Bend the elbows, lowering the top of the head toward the floor between the hands.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Bend the elbows, lowering the top of the head toward the floor between the hands."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Dobla los codos bajando la coronilla hacia el suelo, entre las manos."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Dobre os cotovelos descendo o topo da cabeça em direção ao chão, entre as mãos."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Сгибай локти, опуская макушку к полу между ладонями."
          }
        }
      }
    },
    "Press back up without dropping the hips.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Press back up without dropping the hips."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Empuja hacia arriba sin dejar caer la cadera."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Empurre para cima sem deixar o quadril cair."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Выжми себя вверх, не опуская таз."
          }
        }
      }
    },
    "Hips dropping as the arms bend — keep the V shape.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Hips dropping as the arms bend — keep the V shape."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La cadera baja al doblar los brazos: mantén la forma de V."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O quadril desce quando os braços dobram: mantenha o formato de V."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Таз опускается при сгибании рук — сохраняй угол."
          }
        }
      }
    },
    "Bumping the head on the floor — lower slowly, with control.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Bumping the head on the floor — lower slowly, with control."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Golpear la cabeza contra el suelo: baja despacio, con control."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Bater a cabeça no chão: desça devagar, com controle."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Голова бьется об пол — опускайся медленно, на контроле."
          }
        }
      }
    },
    "Wall handstand push-up": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Wall handstand push-up"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Flexión en vertical contra la pared"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Flexão em parada de mão na parede"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Отжимания в стойке у стены"
          }
        }
      }
    },
    "Kick up into a handstand with your back to the wall, heels resting on it.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Kick up into a handstand with your back to the wall, heels resting on it."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Sube a la vertical de espaldas a la pared, con los talones apoyados en ella."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Suba na parada de mão de costas para a parede, com os calcanhares apoiados nela."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Выйди в стойку на руках спиной к стене, пятки на стене."
          }
        }
      }
    },
    "Bend the elbows slowly, lowering the top of the head toward the floor.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Bend the elbows slowly, lowering the top of the head toward the floor."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Dobla los codos despacio, bajando la coronilla hacia el suelo."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Dobre os cotovelos devagar, descendo o topo da cabeça em direção ao chão."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Медленно сгибай локти, опуская макушку к полу."
          }
        }
      }
    },
    "Press back up; know how to exit safely — step down one leg at a time.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Press back up; know how to exit safely — step down one leg at a time."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Empuja hacia arriba; ten claro cómo salir con seguridad: baja una pierna y después la otra."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Empurre para cima; saiba sair com segurança: desça uma perna de cada vez."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Выжми вверх; умей безопасно выйти из стойки — по одной ноге."
          }
        }
      }
    },
    "Arching the lower back — keep the core and glutes tight.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Arching the lower back — keep the core and glutes tight."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Arqueo en la zona lumbar: mantén el abdomen y los glúteos apretados."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Arco na lombar: mantenha o core e os glúteos contraídos."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Прогиб в пояснице — держи мышцы корпуса и ягодицы в напряжении."
          }
        }
      }
    },
    "Elbows drifting outward — track them forward and down.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Elbows drifting outward — track them forward and down."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los codos se abren hacia fuera: llévalos hacia delante y abajo."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Os cotovelos abrem para fora: conduza-os para a frente e para baixo."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Локти разъезжаются в стороны — веди их вперед-вниз."
          }
        }
      }
    },
    "Chest-to-wall handstand push-up": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Chest-to-wall handstand push-up"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Flexión en vertical de cara a la pared"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Flexão em parada de mão de frente para a parede"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Отжимания в стойке грудью к стене"
          }
        }
      }
    },
    "Walk your feet up the wall, chest facing it, body close to vertical.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Walk your feet up the wall, chest facing it, body close to vertical."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Sube caminando con los pies por la pared, el pecho hacia ella y el cuerpo casi vertical."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Suba caminhando com os pés pela parede, o peito voltado para ela e o corpo quase vertical."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Зайди ногами по стене, грудью к ней, тело почти вертикально."
          }
        }
      }
    },
    "Bend the elbows slowly, lowering the head to the floor.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Bend the elbows slowly, lowering the head to the floor."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Dobla los codos despacio, bajando la cabeza hacia el suelo."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Dobre os cotovelos devagar, descendo a cabeça em direção ao chão."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Медленно сгибай локти, опуская голову к полу."
          }
        }
      }
    },
    "Press back up; keep the body in one tight line.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Press back up; keep the body in one tight line."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Empuja hacia arriba; mantén el cuerpo en una línea firme."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Empurre para cima; mantenha o corpo em uma linha firme."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Выжмись вверх; держи тело одной жесткой линией."
          }
        }
      }
    },
    "Arching away from the wall — stay close, ribs tucked in.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Arching away from the wall — stay close, ribs tucked in."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Arquearte separándote de la pared: quédate cerca, con las costillas metidas."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Arquear afastando-se da parede: fique perto, com as costelas encaixadas."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Прогиб от стены — держись ближе, ребра подобраны."
          }
        }
      }
    },
    "Uncontrolled descent — the head must land softly.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Uncontrolled descent — the head must land softly."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Descenso sin control: la cabeza tiene que llegar suave."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Descida sem controle: a cabeça precisa chegar suave."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Неконтролируемое опускание — голова касается пола мягко."
          }
        }
      }
    },
    "Static lunge": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Static lunge"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Zancada estática"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Afundo estático"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Выпады на месте"
          }
        }
      }
    },
    "Step into a lunge stance and stay in it for the whole set.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Step into a lunge stance and stay in it for the whole set."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Colócate en posición de zancada y quédate en ella toda la serie."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Assuma a posição de afundo e permaneça nela durante toda a série."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Шагни в позицию выпада и оставайся в ней весь подход."
          }
        }
      }
    },
    "Drive up through the front heel, torso upright.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Drive up through the front heel, torso upright."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Sube empujando con el talón de delante, el torso erguido."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Suba empurrando com o calcanhar da frente, o tronco ereto."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Вверх через пятку передней ноги, корпус прямой."
          }
        }
      }
    },
    "Front knee traveling far past the toes — take a longer stance.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Front knee traveling far past the toes — take a longer stance."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La rodilla de delante se va muy por delante de la punta: alarga el paso."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O joelho da frente avança muito além da ponta do pé: alongue o passo."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Колено передней ноги уходит далеко за носок — шаг шире."
          }
        }
      }
    },
    "Torso tipping forward — keep the chest up.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Torso tipping forward — keep the chest up."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El torso se va hacia delante: mantén el pecho arriba."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O tronco tomba para a frente: mantenha o peito erguido."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Корпус заваливается вперед — грудь смотрит прямо."
          }
        }
      }
    },
    "Reverse lunge": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Reverse lunge"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Zancada inversa"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Afundo reverso"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Выпады назад"
          }
        }
      }
    },
    "From standing, step back and lower the rear knee almost to the floor.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "From standing, step back and lower the rear knee almost to the floor."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Desde de pie, da un paso atrás y baja la rodilla trasera casi hasta el suelo."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Em pé, dê um passo para trás e desça o joelho de trás quase até o chão."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Из положения стоя шагни назад, опустив заднее колено почти до пола."
          }
        }
      }
    },
    "The front shin stays near vertical; weight on the front heel.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The front shin stays near vertical; weight on the front heel."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La espinilla de delante se mantiene casi vertical; el peso, en el talón de delante."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A canela da frente fica quase vertical; o peso, no calcanhar da frente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Передняя голень вертикальна, вес на пятке передней ноги."
          }
        }
      }
    },
    "Push off and return to standing — that's one rep.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Push off and return to standing — that's one rep."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Empuja y vuelve a la posición de pie: eso es una repetición."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Empurre e volte à posição em pé: isso é uma repetição."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Оттолкнись и вернись в стойку — это один повтор."
          }
        }
      }
    },
    "Too short a step back — the front knee gets overloaded.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Too short a step back — the front knee gets overloaded."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Paso atrás demasiado corto: se sobrecarga la rodilla de delante."
          }
