          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Планка"
          }
        }
      }
    },
    "Forearms on the floor, elbows under the shoulders, feet hip-width.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Forearms on the floor, elbows under the shoulders, feet hip-width."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Antebrazos en el suelo, codos bajo los hombros, pies a la anchura de la cadera."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Antebraços no chão, cotovelos sob os ombros, pés na largura do quadril."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Предплечья на полу, локти под плечами, стопы на ширине таза."
          }
        }
      }
    },
    "One straight line from head to heels; glutes and abs braced.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "One straight line from head to heels; glutes and abs braced."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Una línea recta de la cabeza a los talones; glúteos y abdomen firmes."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Uma linha reta da cabeça aos calcanhares; glúteos e abdômen firmes."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Прямая линия от макушки до пят; ягодицы и пресс в тонусе."
          }
        }
      }
    },
    "Breathe steadily; shaking is fine, a sagging line is not.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Breathe steadily; shaking is fine, a sagging line is not."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Respira de forma regular; temblar es normal, hundirse no."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Respire de forma regular; tremer é normal, afundar não."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Дыши ровно; дрожь мышц — норма, провал линии — стоп."
          }
        }
      }
    },
    "Hips hiked up — easier, but pointless.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Hips hiked up — easier, but pointless."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cadera levantada: es más fácil, pero no sirve de nada."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Quadril empinado: fica mais fácil, mas não adianta nada."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Таз задран вверх — так легче, но бесполезнее."
          }
        }
      }
    },
    "Lower back sagging — that strains the spine; better to stop early.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Lower back sagging — that strains the spine; better to stop early."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La zona lumbar se hunde: eso carga la columna; mejor parar antes."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A lombar afunda: isso sobrecarrega a coluna; melhor parar antes."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Поясница провисает — это риск для спины, лучше закончить раньше."
          }
        }
      }
    },
    "Hollow hold": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Hollow hold"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Hollow hold"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Hollow hold"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "«Лодочка» (удержание)"
          }
        }
      }
    },
    "Lie on your back, press the lower back into the floor, arms extended overhead.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Lie on your back, press the lower back into the floor, arms extended overhead."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Acostado boca arriba, pega la zona lumbar al suelo y estira los brazos por encima de la cabeza."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Deitado de costas, cole a lombar no chão e estenda os braços acima da cabeça."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Лежа на спине, прижми поясницу к полу, руки вытяни за голову."
          }
        }
      }
    },
    "Lift the shoulder blades and straight legs 15–20 cm off the floor.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Lift the shoulder blades and straight legs 15–20 cm off the floor."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Despega del suelo las escápulas y las piernas estiradas 15–20 cm."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Tire do chão as escápulas e as pernas esticadas, 15–20 cm."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Оторви лопатки и прямые ноги от пола на 15–20 см."
          }
        }
      }
    },
    "Hold the shape with the lower back pressed down the whole time.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Hold the shape with the lower back pressed down the whole time."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Mantén la forma con la zona lumbar pegada al suelo todo el rato."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Segure o formato com a lombar colada no chão o tempo todo."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Держи «лодочку», поясница все время прижата."
          }
        }
      }
    },
    "Lower back lifting off the floor — raise the legs higher or bend the knees.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Lower back lifting off the floor — raise the legs higher or bend the knees."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La zona lumbar se despega del suelo: sube más las piernas o dobla las rodillas."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A lombar sai do chão: suba mais as pernas ou dobre os joelhos."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Поясница отрывается от пола — подними ноги выше или согни колени."
          }
        }
      }
    },
    "Holding your breath — keep breathing shallow and steady.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Holding your breath — keep breathing shallow and steady."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Aguantar la respiración: respira suave y de forma regular."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Prender a respiração: respire leve e de forma regular."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Задержка дыхания — дыши ровно и неглубоко."
          }
        }
      }
    },
    "Long-lever plank": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Long-lever plank"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Plancha con palanca larga"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Prancha com alavanca longa"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Планка с удлиненным рычагом"
          }
        }
      }
    },
    "Take a plank on the forearms, elbows well ahead of the shoulders.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Take a plank on the forearms, elbows well ahead of the shoulders."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ponte en plancha sobre los antebrazos, con los codos bastante por delante de los hombros."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Fique em prancha sobre os antebraços, com os cotovelos bem à frente dos ombros."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Встань в планку на предплечьях, локти заметно впереди плеч."
          }
        }
      }
    },
    "Keep one straight line from head to heels, glutes tight.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Keep one straight line from head to heels, glutes tight."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Mantén una línea recta de la cabeza a los talones, con los glúteos apretados."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Mantenha uma linha reta da cabeça aos calcanhares, com os glúteos contraídos."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Держи одну прямую линию от макушки до пят, ягодицы в тонусе."
          }
        }
      }
    },
    "The farther the elbows, the harder — breathe steadily and hold.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The farther the elbows, the harder — breathe steadily and hold."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cuanto más lejos los codos, más difícil: respira de forma regular y aguanta."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Quanto mais longe os cotovelos, mais difícil: respire de forma regular e segure."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Чем дальше локти, тем тяжелее — дыши ровно и держи."
          }
        }
      }
    },
    "Hips sagging — tuck the pelvis and brace the abs.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Hips sagging — tuck the pelvis and brace the abs."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La cadera se hunde: bascula la pelvis y aprieta el abdomen."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O quadril afunda: incline a pelve e contraia o abdômen."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Таз провисает — подкрути таз и напряги пресс."
          }
        }
      }
    },
    "Elbows too far too soon — increase the lever gradually.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Elbows too far too soon — increase the lever gradually."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Codos demasiado lejos demasiado pronto: alarga la palanca poco a poco."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Cotovelos longe demais cedo demais: aumente a alavanca aos poucos."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Локти слишком далеко сразу — удлиняй рычаг постепенно."
          }
        }
      }
    },
    "Bird dog (hold)": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Bird dog (hold)"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Bird dog (isometría)"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Bird dog (isometria)"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "«Птица-собака» (удержание)"
          }
        }
      }
    },
    "On all fours: hands under the shoulders, knees under the hips.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "On all fours: hands under the shoulders, knees under the hips."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "A cuatro patas: manos bajo los hombros, rodillas bajo la cadera."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "De quatro apoios: mãos sob os ombros, joelhos sob o quadril."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "На четвереньках: ладони под плечами, колени под тазом."
          }
        }
      }
    },
    "Extend the opposite arm and leg into one line with the torso.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Extend the opposite arm and leg into one line with the torso."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Extiende el brazo y la pierna contrarios hasta alinearlos con el torso."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Estenda o braço e a perna opostos até alinhá-los com o tronco."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Вытяни противоположные руку и ногу в одну линию с корпусом."
          }
        }
      }
    },
    "Hold without wobbling; pelvis and shoulders stay level.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Hold without wobbling; pelvis and shoulders stay level."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Aguanta sin balancearte; pelvis y hombros se mantienen nivelados."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Segure sem balançar; pelve e ombros ficam nivelados."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Держи, не раскачиваясь; таз и плечи параллельны полу."
          }
        }
      }
    },
    "Lower back arching as the leg lifts — the leg goes no higher than the torso.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Lower back arching as the leg lifts — the leg goes no higher than the torso."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Arqueo lumbar al subir la pierna: la pierna no sube más que el torso."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Arco na lombar quando a perna sobe: a perna não passa da altura do tronco."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Прогиб в пояснице при подъеме ноги — нога не выше корпуса."
          }
        }
      }
    },
    "Torso rotating — imagine a glass of water on your lower back.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Torso rotating — imagine a glass of water on your lower back."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El torso rota: imagina un vaso de agua apoyado en tu zona lumbar."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O tronco gira: imagine um copo d'água apoiado na sua lombar."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Корпус разворачивается — представь стакан воды на пояснице."
          }
        }
      }
    },
    "Side plank": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Side plank"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Plancha lateral"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Prancha lateral"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Боковая планка"
          }
        }
      }
    },
    "Lie on your side, elbow under the shoulder, feet stacked.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Lie on your side, elbow under the shoulder, feet stacked."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Acuéstate de lado, con el codo bajo el hombro y un pie sobre el otro."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Deite de lado, com o cotovelo sob o ombro e um pé sobre o outro."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Лежа на боку, локоть под плечом, стопы друг на друге."
          }
        }
      }
    },
    "Lift the hips until feet–hips–shoulders form a straight line.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Lift the hips until feet–hips–shoulders form a straight line."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Sube la cadera hasta que pies, cadera y hombros formen una línea recta."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Suba o quadril até pés, quadril e ombros formarem uma linha reta."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Подними таз до прямой линии стопы—таз—плечи."
          }
        }
      }
    },
    "Hold without letting the hips drop; free hand on the waist or up.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Hold without letting the hips drop; free hand on the waist or up."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Aguanta sin dejar caer la cadera; la mano libre en la cintura o hacia arriba."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Segure sem deixar o quadril cair; a mão livre na cintura ou para cima."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Держи, не позволяя тазу опускаться; свободная рука на поясе или вверх."
          }
        }
      }
    },
    "Hips sagging — keep the body line straight.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Hips sagging — keep the body line straight."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La cadera se hunde: la línea del cuerpo tiene que estar recta."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O quadril afunda: a linha do corpo precisa ficar reta."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Таз провисает вниз — линия тела должна быть прямой."
          }
        }
      }
    },
    "Torso tipping forward — shoulders and hips in one plane.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Torso tipping forward — shoulders and hips in one plane."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El torso se va hacia delante: hombros y cadera en un mismo plano."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O tronco tomba para a frente: ombros e quadril no mesmo plano."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Заваливание корпуса вперед — плечи и таз в одной плоскости."
          }
        }
      }
    },
    "Side plank with leg raise": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Side plank with leg raise"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Plancha lateral con elevación de pierna"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Prancha lateral com elevação de perna"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Боковая планка с подъемом ноги"
          }
        }
      }
    },
    "Get into a side plank on the elbow.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Get into a side plank on the elbow."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Colócate en plancha lateral sobre el codo."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Assuma a prancha lateral apoiado no cotovelo."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Встань в боковую планку на локте."
          }
        }
      }
    },
    "Raise the top leg 20–30 cm and hold it straight.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Raise the top leg 20–30 cm and hold it straight."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Sube la pierna de arriba 20–30 cm y mantenla estirada."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Suba a perna de cima 20–30 cm e mantenha-a esticada."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Подними верхнюю ногу на 20–30 см и держи ее прямой."
          }
        }
      }
    },
    "Hips high, the body in one plane.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Hips high, the body in one plane."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La cadera alta y el cuerpo en un mismo plano."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O quadril alto e o corpo no mesmo plano."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Таз высоко, тело — одна плоскость."
          }
        }
      }
    },
    "Hips dropping when the leg lifts — stabilize the plank first.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Hips dropping when the leg lifts — stabilize the plank first."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La cadera cae al subir la pierna: primero consigue una plancha estable."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O quadril cai quando a perna sobe: primeiro deixe a prancha estável."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Таз падает при подъеме ноги — сначала добейся устойчивой планки."
          }
        }
      }
    },
    "Leg drifting forward — keep it in line with the torso.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Leg drifting forward — keep it in line with the torso."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La pierna se va hacia delante: mantenla alineada con el torso."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A perna vai para a frente: mantenha-a alinhada com o tronco."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Нога уходит вперед — держи ее в линии с корпусом."
          }
        }
      }
    },
    "Star side plank": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Star side plank"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Plancha lateral en estrella"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Prancha lateral em estrela"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Боковая планка «звезда»"
          }
        }
      }
    },
    "From a side plank, raise the top leg and the top arm at once.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "From a side plank, raise the top leg and the top arm at once."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Desde la plancha lateral, sube a la vez la pierna y el brazo de arriba."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Da prancha lateral, suba ao mesmo tempo a perna e o braço de cima."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Из боковой планки подними верхнюю ногу и верхнюю руку одновременно."
          }
        }
      }
    },
    "The body forms a star: straight line plus raised limbs.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The body forms a star: straight line plus raised limbs."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El cuerpo forma una estrella: la línea recta más las extremidades levantadas."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O corpo forma uma estrela: a linha reta mais os membros levantados."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Тело образует звезду: прямая линия плюс поднятые конечности."
          }
        }
      }
    },
    "Hips high the whole hold; look straight ahead.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Hips high the whole hold; look straight ahead."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La cadera alta durante todo el ejercicio; la mirada al frente."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O quadril alto durante todo o exercício; o olhar à frente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Таз высоко все удержание; взгляд перед собой."
          }
        }
      }
    },
    "Hips dropping — the base line comes first, the star second.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Hips dropping — the base line comes first, the star second."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La cadera cae: primero la línea base, después la estrella."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O quadril cai: primeiro a linha base, depois a estrela."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Таз опускается — сначала базовая линия, потом «звезда»."
          }
        }
      }
    },
    "Body folding forward — shoulders, hips and legs in one plane.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Body folding forward — shoulders, hips and legs in one plane."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El cuerpo se pliega hacia delante: hombros, cadera y piernas en un mismo plano."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O corpo dobra para a frente: ombros, quadril e pernas no mesmo plano."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Тело складывается вперед — плечи, таз и ноги в одной плоскости."
          }
        }
      }
    },
    "Calf raises": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Calf raises"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elevaciones de talones"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Elevação de panturrilha"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Подъемы на носки"
          }
        }
      }
    },
    "Stand with feet hip-width; hand on a wall for balance.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Stand with feet hip-width; hand on a wall for balance."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "De pie con los pies a la anchura de la cadera; una mano en la pared para equilibrarte."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Em pé com os pés na largura do quadril; uma mão na parede para equilibrar."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Стоя, стопы на ширине таза; рука на стене для равновесия."
          }
        }
      }
    },
    "Rise as high as you can onto the balls of the feet, pause a second at the top.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Rise as high as you can onto the balls of the feet, pause a second at the top."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Sube todo lo que puedas sobre las puntas de los pies y haz una pausa de un segundo arriba."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Suba o máximo que conseguir na ponta dos pés e faça uma pausa de um segundo em cima."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Поднимись на носки максимально высоко, секунда паузы вверху."
          }
        }
      }
    },
    "Lower slowly; for more range, stand with the toes on a step edge.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Lower slowly; for more range, stand with the toes on a step edge."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Baja despacio; para más recorrido, apoya las puntas en el borde de un escalón."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Desça devagar; para mais amplitude, apoie as pontas dos pés na borda de um degrau."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Медленно опустись; для амплитуды — носки на край ступеньки."
          }
        }
      }
    },
    "Fast bouncing — move slowly with a pause at the top.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Fast bouncing — move slowly with a pause at the top."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Rebotes rápidos: muévete despacio y con pausa arriba."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Repiques rápidos: mova devagar e com pausa em cima."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Быстрые «отскоки» — работай медленно, с паузой вверху."
          }
        }
      }
    },
    "Cutting the range — rise all the way up.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Cutting the range — rise all the way up."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Recorrido corto: sube del todo."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Amplitude curta: suba até o fim."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Неполная амплитуда — тянись вверх до конца."
          }
        }
      }
    },
    "Single-leg calf raise": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Single-leg calf raise"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elevación de talón a una pierna"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Elevação de panturrilha unilateral"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Подъемы на носки на одной ноге"
          }
        }
      }
    },
    "Stand on one leg, hand on a wall for balance.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Stand on one leg, hand on a wall for balance."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "De pie sobre una pierna, con una mano en la pared para equilibrarte."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Em pé sobre uma perna, com uma mão na parede para equilibrar."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Стоя на одной ноге, рука на стене для равновесия."
          }
        }
      }
    },
    "Rise onto the ball of the foot as high as possible, pause for a second.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Rise onto the ball of the foot as high as possible, pause for a second."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Sube sobre la punta del pie todo lo que puedas y haz una pausa de un segundo."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Suba na ponta do pé o máximo possível e faça uma pausa de um segundo."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Поднимись на носок максимально высоко, пауза секунда."
          }
        }
      }
    },
    "Lower slowly, heel to the floor (or below step level).": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Lower slowly, heel to the floor (or below step level)."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Baja despacio, con el talón hasta el suelo (o por debajo del escalón)."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Desça devagar, com o calcanhar até o chão (ou abaixo do degrau)."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Медленно вниз, пятка до пола (или ниже ступеньки)."
          }
        }
      }
    },
    "Helping with the other leg — it stays off the floor.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Helping with the other leg — it stays off the floor."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ayudarte con la otra pierna: se queda en el aire."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajudar com a outra perna: ela fica no ar."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Помощь второй ногой — она полностью в воздухе."
          }
        }
      }
    },
    "Ankle rolling outward — press through the big toe.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Ankle rolling outward — press through the big toe."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El tobillo se va hacia fuera: haz fuerza a través del dedo gordo."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O tornozelo cai para fora: faça força pelo dedão."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Заваливание стопы наружу — давление через большой палец."
          }
        }
      }
    },
    "Single-leg calf raise with pause": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Single-leg calf raise with pause"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elevación de talón a una pierna con pausa"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Elevação de panturrilha unilateral com pausa"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Подъемы на одной ноге с паузой"
          }
        }
      }
    },
    "Same as the single-leg raise, but with a 3-second pause at the top.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Same as the single-leg raise, but with a 3-second pause at the top."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Igual que a una pierna, pero con una pausa de 3 segundos arriba."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Igual à unilateral, mas com uma pausa de 3 segundos em cima."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "То же, что на одной ноге, но с паузой 3 секунды вверху."
          }
        }
      }
    },
    "Up in 1 second, hold for 3, down for 3.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Up in 1 second, hold for 3, down for 3."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Sube en 1 segundo, aguanta 3 y baja en 3."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Suba em 1 segundo, segure 3 e desça em 3."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Вверх 1 секунду, держи 3, вниз 3."
          }
        }
      }
    },
    "Full range beats rep count.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Full range beats rep count."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El recorrido completo vale más que el número de repeticiones."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A amplitude completa vale mais que o número de repetições."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Полная амплитуда важнее количества."
          }
        }
      }
    },
    "Skipping the pause — hold an honest 3 seconds at the top.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Skipping the pause — hold an honest 3 seconds at the top."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Saltarte la pausa: aguanta 3 segundos honestos arriba."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Pular a pausa: segure 3 segundos honestos em cima."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Пауза «проскакивается» — честные 3 секунды вверху."
          }
        }
      }
    },
    "Knee bending — the leg stays straight; only the ankle works.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Knee bending — the leg stays straight; only the ankle works."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La rodilla se dobla: la pierna se queda estirada; solo trabaja el tobillo."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O joelho dobra: a perna fica esticada; só o tornozelo trabalha."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Колено сгибается — нога прямая, работает только голеностоп."
          }
        }
      }
    },
    "Single-leg calf raise on a step": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Single-leg calf raise on a step"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elevación de talón a una pierna en un escalón"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Elevação de panturrilha unilateral no degrau"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Подъемы на одной ноге на ступеньке"
          }
        }
      }
    },
    "Stand on one leg with the ball of the foot on a step edge.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Stand on one leg with the ball of the foot on a step edge."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "De pie sobre una pierna, con la punta del pie en el borde de un escalón."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Em pé sobre uma perna, com a ponta do pé na borda de um degrau."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Стоя на одной ноге, носок на краю ступеньки."
          }
        }
      }
    },
    "Lower the heel below the step level, feel the stretch.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Lower the heel below the step level, feel the stretch."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Baja el talón por debajo del escalón y nota el estiramiento."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Desça o calcanhar abaixo do degrau e sinta o alongamento."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Опусти пятку ниже уровня ступеньки, почувствуй растяжение."
          }
        }
      }
    },
    "Rise as high as possible, pause a second, lower for 3 seconds.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Rise as high as possible, pause a second, lower for 3 seconds."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Sube todo lo que puedas, pausa de un segundo y baja en 3 segundos."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Suba o máximo possível, pausa de um segundo e desça em 3 segundos."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Поднимись максимально высоко, секунда паузы, вниз 3 секунды."
          }
        }
      }
    },
    "Short bottom range — the heel must drop below the step.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Short bottom range — the heel must drop below the step."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Poco recorrido abajo: el talón tiene que bajar por debajo del escalón."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Pouca amplitude embaixo: o calcanhar precisa descer abaixo do degrau."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Короткая нижняя фаза — пятка должна уходить ниже ступеньки."
          }
        }
      }
    },
    "Bouncing out of the stretch — pause briefly at the bottom too.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Bouncing out of the stretch — pause briefly at the bottom too."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Rebotar desde el estiramiento: haz también una pausa corta abajo."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Repicar a partir do alongamento: faça também uma pausa curta embaixo."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Отскок из растяжения — внизу тоже короткая пауза."
          }
        }
      }
    },
