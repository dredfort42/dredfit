        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Lift the shoulder blades and straight legs 15–20 cm off the floor."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Оторви лопатки и прямые ноги от пола на 15–20 см."
