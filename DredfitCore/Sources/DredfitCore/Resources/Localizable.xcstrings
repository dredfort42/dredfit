    },
    "Hollow hold": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Hollow hold"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "«Лодочка» (удержание)"
          }
        }
      }
    },
    "Lie on your back, press the lower back into the floor, arms extended overhead.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Lie on your back, press the lower back into the floor, arms extended overhead."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Лёжа на спине, прижми поясницу к полу, руки вытяни за голову."
