      }
    },
    "Hold the shape with the lower back pressed down the whole time.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Hold the shape with the lower back pressed down the whole time."
