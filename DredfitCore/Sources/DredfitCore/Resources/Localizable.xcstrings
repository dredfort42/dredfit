    "Grab the bar slightly wider than shoulder width, palms facing away.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Grab the bar slightly wider than shoulder width, palms facing away."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Agarra la barra algo más abierto que la anchura de los hombros, con las palmas hacia fuera."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Segure a barra um pouco mais aberto que a largura dos ombros, com as palmas para fora."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Возьмись за перекладину хватом чуть шире плеч, ладони от себя."
          }
        }
      }
    },
    "Hang on straight arms and pull the shoulders slightly down — an active hang, head not shrugged in.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Hang on straight arms and pull the shoulders slightly down — an active hang, head not shrugged in."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cuélgate con los brazos estirados y baja un poco los hombros: es una suspensión activa, sin meter la cabeza entre ellos."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Pendure-se com os braços esticados e puxe os ombros levemente para baixo: a pendurada é ativa, sem encolher a cabeça."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Повисни на прямых руках и слегка потяни плечи вниз — вис активный, голова не втянута."
          }
        }
      }
    },
    "Keep the body tight, legs together; breathe steadily for the whole hang.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Keep the body tight, legs together; breathe steadily for the whole hang."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Mantén el cuerpo firme y las piernas juntas; respira de forma regular durante toda la suspensión."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Mantenha o corpo firme e as pernas juntas; respire de forma regular durante toda a pendurada."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Держи корпус собранным, ноги вместе; дыши ровно все время виса."
          }
        }
      }
    },
    "Shoulders at the ears — pull the shoulder blades down; the hang must be active.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Shoulders at the ears — pull the shoulder blades down; the hang must be active."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Hombros pegados a las orejas: lleva las escápulas hacia abajo; la suspensión tiene que ser activa."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Ombros colados nas orelhas: puxe as escápulas para baixo; a pendurada precisa ser ativa."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Плечи у ушей — потяни лопатки вниз, вис должен быть активным."
          }
        }
      }
    },
    "Swinging — keep the body braced, no pendulum.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Swinging — keep the body braced, no pendulum."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Balanceo: mantén el cuerpo firme, sin hacer de péndulo."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Balanço: mantenha o corpo firme, sem virar pêndulo."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Раскачивание — держи корпус в тонусе, без маятника."
          }
        }
      }
    },
    "Step on a support or jump so the chin ends up above the bar.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Step on a support or jump so the chin ends up above the bar."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Súbete a un apoyo o salta para dejar la barbilla por encima de la barra."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Suba num apoio ou salte para deixar o queixo acima da barra."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Встань на опору или подпрыгни так, чтобы подбородок оказался над перекладиной."
          }
        }
      }
    },
    "Lower yourself slowly to straight arms over 3–5 seconds, controlling every inch.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Lower yourself slowly to straight arms over 3–5 seconds, controlling every inch."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Baja despacio hasta estirar los brazos, durante 3–5 segundos, controlando cada centímetro."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Desça devagar até esticar os braços, ao longo de 3–5 segundos, controlando cada centímetro."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Медленно опускайся на прямые руки 3–5 секунд, контролируя каждый сантиметр."
          }
        }
      }
    },
    "Get back on the support and repeat — no pulling up needed.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Get back on the support and repeat — no pulling up needed."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Vuelve al apoyo y repite: no hace falta subir a pulso."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Volte para o apoio e repita: não precisa subir na força."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Вернись на опору и повтори — подниматься силой не нужно."
          }
        }
      }
    },
    "Dropping instead of lowering — the negative takes at least 3 seconds.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Dropping instead of lowering — the negative takes at least 3 seconds."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Dejarte caer en vez de bajar: la negativa dura al menos 3 segundos."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Cair em vez de descer: a negativa dura pelo menos 3 segundos."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Падение вместо опускания — негатив длится не меньше 3 секунд."
          }
        }
      }
    },
    "Relaxed shoulders at the bottom — keep the shoulder blades engaged to the end.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Relaxed shoulders at the bottom — keep the shoulder blades engaged to the end."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Hombros relajados abajo: mantén las escápulas activas hasta el final."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Ombros relaxados embaixo: mantenha as escápulas ativas até o fim."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Расслабленные плечи внизу — держи лопатки в тонусе до конца."
          }
        }
      }
    },
    "Hang on straight arms, grip slightly wider than shoulders, palms facing away.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Hang on straight arms, grip slightly wider than shoulders, palms facing away."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cuélgate con los brazos estirados, con el agarre algo más abierto que los hombros y las palmas hacia fuera."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Pendure-se com os braços esticados, a pegada um pouco mais aberta que os ombros e as palmas para fora."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Повисни на прямых руках, хват чуть шире плеч, ладони от себя."
          }
        }
      }
    },
    "Start by squeezing the shoulder blades and pull up to a right angle at the elbows.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Start by squeezing the shoulder blades and pull up to a right angle at the elbows."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Empieza juntando las escápulas y sube hasta formar un ángulo recto con los codos."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Comece juntando as escápulas e puxe até formar um ângulo reto nos cotovelos."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Начни со сведения лопаток и подтянись до прямого угла в локтях."
          }
        }
      }
    },
    "Lower slowly to straight arms — that's one rep.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Lower slowly to straight arms — that's one rep."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Baja despacio hasta estirar los brazos: eso es una repetición."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Desça devagar até esticar os braços: isso é uma repetição."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Медленно опустись на прямые руки — это один повтор."
          }
        }
      }
    },
    "Jerking and kicking with the legs — only the back and arms work.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Jerking and kicking with the legs — only the back and arms work."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tirones y patadas con las piernas: solo trabajan la espalda y los brazos."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Arrancos e chutes com as pernas: só as costas e os braços trabalham."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Рывки и помощь ногами — работают только спина и руки."
          }
        }
      }
    },
    "Cutting the bottom range — every rep starts from fully straight arms.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Cutting the bottom range — every rep starts from fully straight arms."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Recortar el recorrido abajo: cada repetición empieza con los brazos del todo estirados."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Cortar a amplitude embaixo: cada repetição começa com os braços totalmente esticados."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Срезанная амплитуда внизу — каждый повтор с полностью прямых рук."
          }
        }
      }
    },
    "Pull up, starting by squeezing the shoulder blades, until the chin rises above the bar.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pull up, starting by squeezing the shoulder blades, until the chin rises above the bar."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Sube empezando por juntar las escápulas, hasta que la barbilla pase por encima de la barra."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Puxe começando por juntar as escápulas, até o queixo passar acima da barra."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Подтянись, начиная со сведения лопаток, пока подбородок не поднимется над перекладиной."
          }
        }
      }
    },
    "Lower under control to fully straight arms, no swinging.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Lower under control to fully straight arms, no swinging."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Baja con control hasta estirar del todo los brazos, sin balanceo."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Desça com controle até esticar os braços por completo, sem balanço."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Опустись подконтрольно до полностью прямых рук, без раскачки."
          }
        }
      }
    },
    "Swinging and jerking the body — kipping doesn't count.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Swinging and jerking the body — kipping doesn't count."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Balancear el cuerpo y hacer tirones: el kipping no cuenta."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Balançar e dar arrancos com o corpo: kipping não conta."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Раскачивание и рывки корпусом — киппинг не считается."
          }
        }
      }
    },
    "Half range at the bottom — each rep starts from straight arms.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Half range at the bottom — each rep starts from straight arms."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Medio recorrido abajo: cada repetición empieza con los brazos estirados."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Meia amplitude embaixo: cada repetição começa com os braços esticados."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Неполное разгибание рук внизу — повтор начинается с прямых рук."
          }
        }
      }
    }
  },
  "version": "1.0"
}