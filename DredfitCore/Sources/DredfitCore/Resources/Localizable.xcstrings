      }
    },
    "Reaching with the chin instead of the chest — lead with the chest.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Reaching with the chin instead of the chest — lead with the chest."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Llegar con la barbilla en lugar del pecho: guía el movimiento con el pecho."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
