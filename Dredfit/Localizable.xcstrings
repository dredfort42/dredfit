    " · " : {

    },
    " · %@" : {
      "comment" : "A separator dot followed by the sign of the level change."
    },
    " /side" : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : " /lado"
          }
        },
        "pt-BR" : {
