    },
    "No details saved for this workout." : {
      "localizations" : {
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Детали этой тренировки не сохранились."
          }
        }
      }
    },
    "No questions about your goal, your level or how much time you have. Open the app and train — the first workout is already waiting. About 33 minutes, no equipment." : {
      "extractionState" : "manual",
      "localizations" : {
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Никаких вопросов про цель, уровень и свободное время. Открыл — и тренируешься: первая тренировка уже готова. Около 33 минут, без инвентаря."
          }
        }
      }
    },
    "Now %lld sets" : {
      "localizations" : {
        "en" : {
          "variations" : {
            "plural" : {
